# sysbox deployment overrides
# Copy to .env and edit locally. .env is intentionally git-ignored.
#
#   cp .env.example .env
#   make api-up
#
# Service defaults live in deploy/docker/sysbox.yaml and are mounted as
# /etc/sysbox/sysbox.yaml. Keep .env focused on host-specific wiring:
# deployment profile, published ports, bind mounts, and secrets.

# Deployment profile selected by Makefile:
#   service      API + Postgres + Docker socket, ordinary Compose networking
#   netns        service + host netns/veth/tap privileges
#   firecracker  netns + /dev/kvm + SYSBOX_FIRECRACKER_BIN mount
#   libvirt      netns + /var/run/libvirt mount
#   full         firecracker + libvirt
SYSBOX_DEPLOYMENT=service

# API deployment wiring
SYSBOX_API_PORT=9876
SYSBOX_CONFIG=/etc/sysbox/sysbox.yaml
SYSBOX_API_TOKEN=

# Host bind mounts and their container targets.
SYSBOX_HOME=/var/lib/sysbox
SYSBOX_CACHE=/var/cache/sysbox
SYSBOX_DATA_DIR=.sysbox/api
SYSBOX_CACHE_DIR=~/.cache/sysbox
SYSBOX_DOCKER_SOCKET=/var/run/docker.sock

# Postgres backing store used by Docker Compose.
SYSBOX_POSTGRES_DB=sysbox
SYSBOX_POSTGRES_USER=sysbox
SYSBOX_POSTGRES_PASSWORD=sysbox
SYSBOX_POSTGRES_PORT=55432

# Leave empty to use deploy/docker/sysbox.yaml for service mode. Host-network
# profiles override this in compose.netns.yml because Compose DNS is unavailable.
# Set only when using an external backend.
SYSBOX_STATE_BACKEND=

# Firecracker profile. Host path is required only when
# SYSBOX_DEPLOYMENT=firecracker/full; the container path is configured in
# deploy/docker/sysbox.yaml as /opt/sysbox/bin/firecracker.
SYSBOX_FIRECRACKER_BIN=

# Example/local lab helpers. These are not API deployment contracts.
SYSBOX_ROOTFS=
SYSBOX_QCOW2=

# Optional LLM settings for example agents/labs.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
SYSBOX_MODEL=anthropic/claude-sonnet-4-5
SYSBOX_MAX_TURNS=30
SYSBOX_RULES_DIR=rules
