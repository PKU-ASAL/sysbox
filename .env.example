# sysbox environment configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── LLM API ───────────────────────────────────────────────────────────────────

# API key. For Anthropic: https://platform.claude.com/
# For DeepSeek via Anthropic-compatible API, use your DeepSeek key here.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the Anthropic SDK base URL.
# DeepSeek Anthropic-compatible endpoint:
#   ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# Default (native Anthropic):
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── Model selection ───────────────────────────────────────────────────────────

# Model for the attack agent in opencode provider/model format.
# opencode reads this via {env:SYSBOX_MODEL} in opencode.json inside the container.
#
# Anthropic (native):
#   SYSBOX_MODEL=anthropic/claude-sonnet-4-5
#   SYSBOX_MODEL=anthropic/claude-haiku-3-5
#
# DeepSeek via Anthropic-compatible API (set ANTHROPIC_BASE_URL above):
#   SYSBOX_MODEL=anthropic/deepseek-v4-pro
#   SYSBOX_MODEL=anthropic/deepseek-chat
SYSBOX_MODEL=anthropic/claude-sonnet-4-5

# ── Episode defaults ──────────────────────────────────────────────────────────

# Maximum Bash tool calls per episode before the agent is stopped.
SYSBOX_MAX_TURNS=30

# Path to sysbox state file (relative to repo root or absolute).
SYSBOX_STATE_FILE=runs/default/state.json

# Path to rules directory (relative to repo root or absolute).
SYSBOX_RULES_DIR=rules
