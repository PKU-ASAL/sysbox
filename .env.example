# sysbox environment configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── Anthropic API ─────────────────────────────────────────────────────────────

# API key from https://platform.claude.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override default API endpoint.
# Use this for proxies, local LLMs, AWS Bedrock, Azure, or corporate gateways.
# Default: https://api.anthropic.com
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── Model selection ───────────────────────────────────────────────────────────

# Claude model to use for the attack agent.
# Default: claude-sonnet-4-5 (fast, cost-effective for RL training)
# Options: claude-opus-4-7, claude-sonnet-4-5, claude-haiku-3-5
SYSBOX_MODEL=claude-sonnet-4-5

# ── Episode defaults ──────────────────────────────────────────────────────────

# Maximum Bash tool calls per episode before the agent is stopped.
SYSBOX_MAX_TURNS=30

# Path to sysbox state file (relative to repo root or absolute).
SYSBOX_STATE_FILE=runs/default/state.json

# Path to rules directory (relative to repo root or absolute).
SYSBOX_RULES_DIR=rules
