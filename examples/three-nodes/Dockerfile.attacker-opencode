FROM ubuntu:24.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    nmap \
    openssh-client \
    openssh-server \
    curl \
    wget \
    netcat-openbsd \
    ca-certificates \
    bash \
    python3 \
    xz-utils \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 22 from TUNA binary mirror
RUN curl -fsSL https://mirrors.tuna.tsinghua.edu.cn/nodejs-release/v22.16.0/node-v22.16.0-linux-x64.tar.xz \
    | tar -xJ -C /usr/local --strip-components=1 \
    && node --version

# Install opencode globally via npmmirror
RUN npm install -g opencode-ai --registry https://registry.npmmirror.com

# SSH server setup for inter-node pivoting
RUN ssh-keygen -A \
    && mkdir -p /root/.ssh \
    && chmod 700 /root/.ssh \
    && printf 'PermitRootLogin yes\nPasswordAuthentication no\nStrictModes no\n' \
       >> /etc/ssh/sshd_config

# opencode config (model + provider read from env vars at runtime via {env:VAR})
RUN mkdir -p /root/.config/opencode
COPY opencode.json /root/.config/opencode/config.json

EXPOSE 4096
CMD ["sleep", "infinity"]
