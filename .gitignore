# sysbox-init: tiny placeholders are committed (so 'go build ./...' works on a
# fresh clone), but `make build-init[-all]` overwrites them with real ELF
# binaries. Use `make setup-init-skip-worktree` to suppress the resulting
# `git status` noise locally.
